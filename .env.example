PORT=3000

# Default job source Airtable public view URL (used to bootstrap config/jobs.json)
AIRTABLE_PUBLIC_URL=https://airtable.com/appXXXX/shrXXXX/tblXXXX

# Default job destination JSON path
OUTPUT_JSON_PATH=./data/jobs/default/current.json

# Default job schedule (used when creating the default job)
EXPORT_SCHEDULE_ENABLED=true
EXPORT_SCHEDULE_CRON=0 17 * * *
EXPORT_SCHEDULE_TZ=Europe/Madrid

# Optional advanced paths
JOBS_CONFIG_PATH=./config/jobs.json
JOBS_STATE_PATH=./data/state/runs.json
SNAPSHOT_ROOT=./data/snapshots

# Retention
MAX_SNAPSHOTS_PER_JOB=30
MAX_HISTORY_PER_JOB=80
